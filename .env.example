# MongoDB Atlas connection string
MONGODB_URI="mongodb://user:password@host:27017/office-expense?ssl=true&authSource=admin"

JWT_SECRET="your-secret-key-here"
AUTH_SECRET="your-secret-key-here"
AUTH_TRUST_HOST="true"

PORT=5000
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:4000"

# n8n — Chile CLP + Pakistan PKR fuel prices (saved to MongoDB)
N8N_FUEL_PRICES_WEBHOOK_URL=""
# Optional: Bearer token when backend pulls from n8n GET webhook
# N8N_FUEL_PRICES_WEBHOOK_AUTH=""
# Optional: secret for POST /api/fuel-prices/webhook and POST /api/fuel-prices/sync
# N8N_FUEL_WEBHOOK_SECRET=""

# --- Vercel production (Vercel Dashboard → backend project → Root Directory: backend) ---
# MONGODB_URI=<Atlas connection string>
# JWT_SECRET=<same as frontend AUTH_SECRET>
# AUTH_SECRET=<same as frontend AUTH_SECRET>
# FRONTEND_URL=https://office-website-gilt.vercel.app
# ADMIN_URL=https://admin-office-nine.vercel.app
